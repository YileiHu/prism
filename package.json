{
  "name": "prism",
  "version": "0.1.0",
  "description": "Personal knowledge management desktop app",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "lint": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "preview": "vite preview",
    "generate-icons": "electron scripts/generate-icons.mjs"
  },
  "keywords": [
    "knowledge-management",
    "obsidian",
    "notes"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.prism.knowledge",
    "productName": "Prism",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "public/icon.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "icon": "public/icon.png"
    },
    "linux": {
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-virtual": "^3.14.6",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "wait-on": "^9.0.10"
  }
}
